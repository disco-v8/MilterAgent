# MilterAgent Configuration File
# 
# This file configures the MilterAgent server settings.
# Reload configuration by sending SIGHUP signal to the process.

# Server listen address and port
# Format: IP:PORT or just PORT (for dual-stack [::]:PORT)
# Examples:
#   Listen 8898                    # IPv4/IPv6 dual-stack on port 8898
#   Listen 192.168.1.100:4000     # IPv4 specific address
#   Listen [::1]:8898              # IPv6 localhost
Listen [::]:8898

# Client inactivity timeout in seconds
# Clients will be disconnected if no data is received within this time
Client_timeout 30

# Subject prefix preparation settings
# Add_Subject_Prefix switches which actions may prepend Subject text.
# 0=disabled, 1=WARN only, 2=REJECT only, 3=WARN and REJECT.
# One trailing space is automatically appended to each prefix value when it is used.
# Write [WARN] or [REJECT] here, and MilterAgent will internally normalize them to "[WARN] " and "[REJECT] ".
# These settings control Subject rewriting when WARN or REJECT is returned.
Add_Subject_Prefix 0
WARN_Subject_Prefix [WARN]
REJECT_Subject_Prefix [REJECT]
